# ---------------------------------------------------------------------------
# Copy to .env.local and fill in your values:
#   Copy-Item .env.example .env.local
#
# Every VITE_* value is bundled into the browser and is PUBLIC.
# Never put a privileged secret behind a VITE_ prefix.
# ---------------------------------------------------------------------------

# --- Appwrite (required) ---------------------------------------------------
# Endpoint keeps the /v1 suffix. Self-hosting? Point this at your own host.
VITE_APPWRITE_ENDPOINT=https://cloud.appwrite.io/v1

# From Appwrite Console -> Overview.
VITE_APPWRITE_PROJECT_ID=your_appwrite_project_id

# Must match the database you created.
VITE_APPWRITE_DATABASE_ID=life_companion

# --- Identity (required) ---------------------------------------------------
# This app has no sign-in. Every document is written with VITE_OWNER_ID as its
# `ownerId`, and every query filters on it.
#
# Pick a value and never change it. Changing it after you have data does not
# delete anything, but the app will stop seeing the old documents — they stay in
# the database, filtered out, and you will appear to have lost everything.
VITE_OWNER_ID=solo

# Display name used when the profile document is first created.
# Editable afterwards in Settings.
VITE_OWNER_NAME=Abhishek

# --- Gemini (optional) -----------------------------------------------------
# Leave blank and the app still works: tasks, XP, habits, journaling, streaks
# and rewards all run, but Aura's responses come from built-in fallbacks
# instead of being generated for you.
#
# NOTE: this key ships in the browser bundle and is readable by anyone who can
# load the app. Use a rate-limited key. Move Gemini behind an Appwrite Function
# before deploying anywhere public.
VITE_GEMINI_API_KEY=your_gemini_api_key
VITE_GEMINI_MODEL=gemini-2.0-flash

# --- Provisioning only (optional) ------------------------------------------
# Deliberately NOT prefixed with VITE_, so Vite never bundles it.
#
# A server API key with the `databases.read` + `databases.write` scopes, used
# solely by `npm run setup:appwrite` to create the collections for you.
# Not needed at all if you build the collections by hand in the console.
# Delete this line once provisioning is done.
APPWRITE_API_KEY=your_appwrite_server_api_key

# --- Rarely needed ---------------------------------------------------------
# Reserved for future file uploads. Nothing uploads files today.
# VITE_APPWRITE_BUCKET_ID=uploads

# Only set these if your collection IDs differ from the defaults shown.
# VITE_COL_PROFILES=profiles
# VITE_COL_TASKS=tasks
# VITE_COL_HABITS=habits
# VITE_COL_HABIT_LOGS=habit_logs
# VITE_COL_JOURNAL=journal_entries
# VITE_COL_PREFERENCES=preferences
# VITE_COL_REWARD_HISTORY=reward_history
# VITE_COL_MEMORY=ai_memory
# VITE_COL_CONVERSATIONS=ai_conversations
# VITE_COL_XP_HISTORY=xp_history
# VITE_COL_DAILY_LOGS=daily_logs
